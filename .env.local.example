# Sanity — haal op via https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=jouw-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Productie-URL voor sitemap/OG/canonical (zonder slash op het eind)
# Stel in zodra het definitieve domein bekend is; fallback = vercel.app
NEXT_PUBLIC_SITE_URL=https://youniekart.vercel.app

# Alleen nodig voor server-side schrijf-acties (import-script)
# SANITY_API_READ_TOKEN=

# Geheim voor de Sanity-webhook → /api/revalidate (instant-publiceren).
# Zelfde waarde invullen in sanity.io/manage → API → Webhooks → Secret.
# SANITY_REVALIDATE_SECRET=
